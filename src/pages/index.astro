<style>
	.landing {
		flex: 1;
		display: flex;
		flex-direction: row;
		align-items: center;
		padding: 0 max(5vw, 3rem);
		gap: 0;
		overflow: hidden;
	}

	/* Left half */
	.left {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		padding-right: 3rem;
	}

	.name {
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: clamp(2.5rem, 5vw, 5rem);
		line-height: 1;
		color: var(--gray-0);
		margin: 0 0 0.75rem;
	}

	.role {
		font-family: var(--font-body);
		font-size: var(--text-sm);
		color: var(--gray-400);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0;
	}

	/* Divider */
	.divider {
		width: 1px;
		align-self: stretch;
		background: var(--gray-800);
		flex-shrink: 0;
		margin: 4rem 0;
	}

	/* Right half */
	.right {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-left: 3rem;
		overflow-y: auto;
		max-height: 100%;
	}

	.bio {
		font-size: var(--text-sm);
		color: var(--gray-300);
		line-height: 1.7;
		margin: 0 0 1rem;
	}

	.bio:last-child {
		margin-bottom: 0;
	}

	[data-dither] {
		cursor: text;
	}

	/* Webring */
	.webring {
		position: fixed;
		bottom: 1.5rem;
		left: 1.5rem;
		z-index: 10;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: var(--text-sm);
	}

	.webring a {
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--theme-transition);
		display: flex;
		align-items: center;
	}

	.webring a svg {
		width: 1.4rem;
		height: 1.4rem;
	}

	.webring a:hover {
		color: var(--accent-regular);
	}

	/* Mobile: stack vertically */
	@media (max-width: 50em) {
		.landing {
			flex-direction: column;
			align-items: flex-start;
			padding: 2rem 1.5rem;
			overflow-y: auto;
			gap: 2rem;
		}

		.left {
			padding-right: 0;
		}

		.name {
			font-size: clamp(2rem, 10vw, 3rem);
		}

		.divider {
			width: 100%;
			height: 1px;
			align-self: auto;
			margin: 0;
		}

		.right {
			padding-left: 0;
			overflow-y: visible;
		}
	}
</style>
