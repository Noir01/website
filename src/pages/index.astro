---
import LandingLayout from "../layouts/LandingLayout.astro";
import Icon from "../components/Icon.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
---

<LandingLayout>
	<main class="landing">
		<div class="content">
			<h1 class="name">Aniruddh Srivastava</h1>
			<p class="role">Software Engineer</p>

			<!-- <p class="tagline">
				Learning something new every day and building useful things
				along the way.
			</p> -->

			<div class="socials">
				<a
					href="https://github.com/Noir01"
					class="social-link"
					aria-label="GitHub"
				>
					<Icon icon="github-logo" size="1.4em" />
				</a>
				<a
					href="https://www.linkedin.com/in/aniruddh-srivastava/"
					class="social-link"
					aria-label="LinkedIn"
				>
					<Icon icon="linkedin-logo" size="1.4em" />
				</a>
			</div>
		</div>
	</main>
	<MusicPlayer />
</LandingLayout>

<style>
	.landing {
		flex: 1;
		display: flex;
		align-items: center;
		padding: 0 max(5vw, 3rem);
	}

	.content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		max-width: 700px;
	}

	.name {
		font-family: var(--font-brand);
		font-weight: 500;
		font-size: clamp(2.5rem, 7vw, 5rem);
		line-height: 1;
		color: var(--gray-0);
		margin: 0 0 0.75rem;
	}

	.role {
		font-family: var(--font-body);
		font-size: var(--text-md);
		color: var(--gray-400);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0;
	}

	.tagline {
		font-size: var(--text-md);
		color: var(--gray-300);
		max-width: 38ch;
		line-height: 1.7;
		margin: 2.5rem 0 0;
	}

	.socials {
		display: flex;
		gap: 0.25rem;
		margin-top: 2.5rem;
	}

	.social-link {
		display: flex;
		padding: 0.4rem;
		color: var(--gray-400);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	.social-link:hover {
		color: var(--gray-0);
	}

	@media (max-width: 50em) {
		.landing {
			padding: 0 1.5rem;
		}

		.name {
			font-size: clamp(2rem, 10vw, 3rem);
		}
	}
</style>
