---
import LandingLayout from "../layouts/LandingLayout.astro";
import Icon from "../components/Icon.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
---

<LandingLayout
	description="Aniruddh Srivastava is a CS Honors student at Purdue University interested in systems programming, formal verification, and FPGA development. Incoming Cloudflare PM Intern."
>
	<main class="landing">
		<div class="left">
			<h1 class="name">Aniruddh Srivastava</h1>
			<p class="role">CS Honors @ <span data-dither="purdue">Purdue</span> · Incoming PM Intern @ <span data-dither="cloudflare">Cloudflare</span> · Systems, Formal Verification, FPGAs</p>
		</div>

		<div class="divider" aria-hidden="true"></div>

		<div class="right">
			<p class="bio">
				Junior in CS Honors at <span data-dither="purdue">Purdue</span> with minors in Math, Physics, and ECE.
				Incoming PM intern at <span data-dither="cloudflare">Cloudflare</span> on the Zero Trust team.
			</p>
			<p class="bio">
				Interested in systems programming, formal verification, and computer architecture.
				Currently researching LLM-assisted theorem proving in Rocq and Lean.
			</p>
			<p class="bio">
				Annual Advent of Code participant.
				Online, I go by Noir.
			</p>
		</div>
	</main>
	<MusicPlayer />
