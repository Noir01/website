			<g fill-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="2">
				<path fill="#FDD34A" d="M720.627 362.058 1080 571.597l348.11-203.284 1.04 405.519 23.72.286 1.24-417.008 348.49 196.999 2.36 837.511-350.53 196.03-.32-425.9L1080 1379.46v430.08l-361.083 205.48-360.459-209.33 1.317-403.07 366.413 210.14 10.851-20.93-363.838-211.46 347.868-203z"/>
