</dither-canvas>

<style>
	dither-canvas {
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	dither-canvas canvas {
		width: 100%;
		height: 100%;
		display: block;
		transition: opacity 0.4s ease-out;
	}
</style>

<script>
	interface DitheredLogo {
		width: number;
		height: number;
		pixels: [number, number][];
		color: string;
	}

	const LOGO_COLORS: Record<string, string> = {
		cloudflare: "#F6821F",
		purdue: "#CFB991",
		"purdue-hackers": "#FDD34A",
	};

	class DitherCanvas extends HTMLElement {
		private canvas!: HTMLCanvasElement;
		private ctx!: CanvasRenderingContext2D;
		private logos: Map<string, DitheredLogo> = new Map();
		private animationId: number | null = null;
		private revealedCount = 0;
		private startTime = 0;
		private currentLogo: string | null = null;
		private fadingOut = false;
		private resizeTimer: ReturnType<typeof setTimeout> | null = null;

		connectedCallback() {
			if (!window.matchMedia("(hover: hover)").matches) return;

			this.canvas = this.querySelector("canvas")!;
			const ctx = this.canvas.getContext("2d");
			if (!ctx) return;
			this.ctx = ctx;

			this.resizeCanvas();
			window.addEventListener("resize", () => this.handleResize());

			document.querySelectorAll<HTMLElement>("[data-dither]").forEach((el) => {
				const key = el.dataset.dither!;
				el.addEventListener("mouseenter", () => this.showLogo(key));
				el.addEventListener("mouseleave", () => this.hideLogo());
			});

			this.preloadLogos();
		}

		private resizeCanvas() {
			this.canvas.width = window.innerWidth;
			this.canvas.height = window.innerHeight;
		}

		private handleResize() {
			if (this.resizeTimer) clearTimeout(this.resizeTimer);
			this.resizeTimer = setTimeout(() => {
				this.cancelAnimation();
				this.resizeCanvas();
				this.logos.clear();
				this.preloadLogos();
			}, 250);
		}

		private async preloadLogos() {
			const templates = this.querySelectorAll<HTMLTemplateElement>("template[data-logo]");
			for (const tpl of templates) {
				const key = tpl.dataset.logo!;
				if (this.logos.has(key)) continue;
				try {
					const dithered = await this.rasterizeAndDither(tpl, key);
					this.logos.set(key, dithered);
				} catch {
					// Skip logos that fail to load
				}
			}
		}

		private rasterizeAndDither(tpl: HTMLTemplateElement, key: string): Promise<DitheredLogo> {
			return new Promise((resolve, reject) => {
				const svgEl = tpl.content.querySelector("svg");
				if (!svgEl) return reject(new Error("No SVG found"));

				const svgClone = svgEl.cloneNode(true) as SVGElement;
				svgClone.setAttribute("xmlns", "http://www.w3.org/2000/svg");
				const svgString = new XMLSerializer().serializeToString(svgClone);
				const blob = new Blob([svgString], { type: "image/svg+xml;charset=utf-8" });
				const url = URL.createObjectURL(blob);

				const img = new Image();
				img.onload = () => {
					URL.revokeObjectURL(url);

					const size = Math.min(this.canvas.width, this.canvas.height) * 0.6;
					const aspect = img.naturalWidth / img.naturalHeight;
					let w: number, h: number;
					if (aspect >= 1) {
						w = Math.round(size);
						h = Math.round(size / aspect);
					} else {
						h = Math.round(size);
						w = Math.round(size * aspect);
					}

					const offscreen = document.createElement("canvas");
					offscreen.width = w;
					offscreen.height = h;
					const offCtx = offscreen.getContext("2d")!;
					offCtx.drawImage(img, 0, 0, w, h);
					const imageData = offCtx.getImageData(0, 0, w, h);

					const pixels = this.floydSteinberg(imageData);
					resolve({
						width: w,
						height: h,
						pixels,
						color: LOGO_COLORS[key] || "#ffffff",
					});
				};
				img.onerror = () => {
					URL.revokeObjectURL(url);
					reject(new Error("Image load failed"));
				};
				img.src = url;
			});
		}

		private floydSteinberg(imageData: ImageData): [number, number][] {
			const { width, height, data } = imageData;
			const gray = new Float32Array(width * height);

			for (let i = 0; i < gray.length; i++) {
				const r = data[i * 4];
				const g = data[i * 4 + 1];
				const b = data[i * 4 + 2];
				const a = data[i * 4 + 3];
				// Transparent pixels are treated as white (background)
				gray[i] = a < 10 ? 255 : 0.299 * r + 0.587 * g + 0.114 * b;
			}

			const active: [number, number][] = [];

			for (let y = 0; y < height; y++) {
				for (let x = 0; x < width; x++) {
					const idx = y * width + x;
					const oldVal = gray[idx];
					const newVal = oldVal < 128 ? 0 : 255;
					if (newVal === 0) active.push([x, y]);
					const error = oldVal - newVal;

					if (x + 1 < width) gray[idx + 1] += error * 7 / 16;
					if (y + 1 < height) {
						if (x - 1 >= 0) gray[idx + width - 1] += error * 3 / 16;
						gray[idx + width] += error * 5 / 16;
						if (x + 1 < width) gray[idx + width + 1] += error * 1 / 16;
					}
				}
			}

			// Shuffle for random reveal order
			for (let i = active.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[active[i], active[j]] = [active[j], active[i]];
			}

			return active;
		}

		private showLogo(key: string) {
			this.cancelAnimation();
			this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
			this.canvas.style.opacity = "1";
			this.fadingOut = false;
			this.revealedCount = 0;
			this.currentLogo = key;

			const logo = this.logos.get(key);
			if (!logo) return;

			this.startTime = performance.now();
			this.animationId = requestAnimationFrame((t) => this.animate(t));
		}

		private hideLogo() {
			if (this.fadingOut) return;
			this.fadingOut = true;
			this.canvas.style.opacity = "0";

			const cleanup = () => {
				this.canvas.removeEventListener("transitionend", cleanup);
				this.cancelAnimation();
				this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
				this.canvas.style.opacity = "1";
				this.fadingOut = false;
				this.currentLogo = null;
				this.revealedCount = 0;
			};
			this.canvas.addEventListener("transitionend", cleanup, { once: true });

			// Fallback in case transitionend doesn't fire
			setTimeout(cleanup, 500);
		}

		private cancelAnimation() {
			if (this.animationId !== null) {
				cancelAnimationFrame(this.animationId);
				this.animationId = null;
			}
		}

		private animate(timestamp: number) {
			if (!this.currentLogo || this.fadingOut) return;

			const logo = this.logos.get(this.currentLogo);
			if (!logo) return;

			const elapsed = timestamp - this.startTime;
			const duration = 1500;
			const progress = Math.min(elapsed / duration, 1);
			// Ease-out cubic
			const eased = 1 - Math.pow(1 - progress, 3);
			const targetCount = Math.floor(eased * logo.pixels.length);

			const offsetX = Math.round((this.canvas.width - logo.width) / 2);
			const offsetY = Math.round((this.canvas.height - logo.height) / 2);

			this.ctx.fillStyle = logo.color;
			this.ctx.globalAlpha = 0.18;

			for (let i = this.revealedCount; i < targetCount; i++) {
				const [x, y] = logo.pixels[i];
				this.ctx.fillRect(offsetX + x, offsetY + y, 1, 1);
			}
			this.revealedCount = targetCount;

			this.ctx.globalAlpha = 1;

			if (progress < 1) {
				this.animationId = requestAnimationFrame((t) => this.animate(t));
			} else {
				this.animationId = null;
			}
		}
	}

	customElements.define("dither-canvas", DitherCanvas);
</script>
