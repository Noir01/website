		<div class="track-info">
			<span class="status"></span>
			<span class="song"></span>
			<span class="artist"></span>
		</div>
	</a>
</spotify-player>

<style>
	spotify-player {
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		z-index: 10;
		opacity: 0;
		transition: opacity 0.3s ease-in-out;
	}

	spotify-player[data-loaded] {
		opacity: 1;
	}

	.widget {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: var(--gray-400);
		transition: color var(--theme-transition);
	}

	.widget:hover {
		color: var(--gray-200);
	}


	.vinyl svg {
		display: block;
		color: var(--gray-500);
		transition: color var(--theme-transition);
	}

	.widget:hover .vinyl svg {
		color: var(--gray-300);
	}

	spotify-player[data-playing="true"] .vinyl svg {
		animation: pulse 2s ease-in-out infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 0.8; }
		50% { opacity: 1; }
	}

	.track-info {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		font-size: var(--text-sm);
		max-width: 200px;
	}

	.status {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.7;
	}

	.song {
		color: var(--gray-200);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.artist {
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	@media (max-width: 50em) {
		spotify-player {
			bottom: 1rem;
			right: 1rem;
		}

		.track-info {
			max-width: 140px;
		}
	}

	@media (max-width: 30em) {
		.track-info {
			display: none;
		}
	}
</style>

<script>
	class SpotifyPlayer extends HTMLElement {
		private interval: ReturnType<typeof setInterval> | null = null;

		connectedCallback() {
			this.fetchTrack();
			this.interval = setInterval(() => this.fetchTrack(), 60_000);
		}

		disconnectedCallback() {
			if (this.interval) clearInterval(this.interval);
		}

		async fetchTrack() {
			try {
				const api = this.dataset.api;
				if (!api) return;

				const res = await fetch(api);
				if (!res.ok) return;

				const data = await res.json();
				if (!data.song) return;

				const link = this.querySelector('a')!;
				const status = this.querySelector('.status')!;
				const song = this.querySelector('.song')!;
				const artist = this.querySelector('.artist')!;

				link.href = data.url || '#';
				status.textContent = data.playing ? 'Now playing' : 'Was listening to';
				song.textContent = data.song;
				artist.textContent = data.artist;

				this.dataset.playing = String(data.playing);
				this.dataset.loaded = '';
			} catch {
				// Silently hide on error
			}
		}
	}

	customElements.define('spotify-player', SpotifyPlayer);
</script>
